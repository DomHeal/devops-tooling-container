{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:base",
    "group:all"
  ],
  "regexManagers": [
    {
      "fileMatch": [
        "(^|/|\\.)Dockerfile$",
        "(^|/)Dockerfile[^/]*$"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[a-z-]+?) depName=(?<depName>[^\s]+?)(?: lookupName=(?<lookupName>[^\s]+?))?(?: versioning=(?<versioning>[a-z-0-9]+?))?\s(?:ENV|ARG) .+?_VERSION=(?<currentValue>.+?)\s"
      ]
    }
  ]
}
